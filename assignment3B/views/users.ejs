<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Database | Home</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 0; padding: 0; }
    header { padding: 20px 40px; border-bottom: 1px solid #eee; }
    header h1 { margin: 0; font-size: 32px; }
    header p { margin: 4px 0 0; color: #666; }
    nav { position: absolute; right: 40px; top: 26px; }
    nav a { margin-left: 20px; text-decoration: none; color: #444; font-weight: bold; }
    main { padding: 40px; }
    h2 { margin-top: 0; }
    .user-list { margin-top: 20px; }
    .user-item { margin-bottom: 10px; }
    .user-item a { color: #007b5e; font-weight: bold; text-decoration: none; }
    .user-item span { margin-left: 10px; color: #555; }
  </style>
</head>
<body>
  <header>
    <h1>MONGODB</h1>
    <p>THIS SITE IS BASED ON DATABASE HANDLING CRUD OPERATIONS</p>
    <nav>
      <a href="/users">HOME</a>
      <a href="/user/create">ADD-USER</a>
    </nav>
  </header>
  <main>
    <h2>All Users</h2>

    <% if (!users || users.length === 0) { %>
      <p>There are no users to display...</p>
    <% } else { %>
      <div class="user-list">
        <% users.forEach(function(user) { %>
          <div class="user-item">
            <a href="/users/<%= user._id %>"><%= user.username %></a>
            <span><%= user.email %></span>
          </div>
        <% }); %>
      </div>
    <% } %>
  </main>
</body>
</html>
